{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/slik_link",
      "dest": "api/slik_link.js"
    },
    {
      "src": "/api/slik_send",
      "dest": "api/slik_send.js"
    },
    {
      "src": "/(.*)",
      "dest": "app/main.py"
    }
  ]
}
